<?xml version="1.0" encoding="utf-8"?>
<!--
    EmergencyActiveActivity layout — Screen 3 (Section 15.4)
    Design: coral emergency banner, 2-column card row, live status feed, bottom action bar.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- ═══ Emergency Banner (top, full width, flush) ═══════════ -->
    <LinearLayout
        android:id="@+id/layout_emergency_banner"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@color/color_emergency_banner_bg"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <!-- Pulsing red dot -->
        <View
            android:id="@+id/v_banner_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#E8574A"/>

        <TextView
            android:id="@+id/tv_banner_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Emergency Activated — Notifying Family"
            android:textSize="16sp"
            android:textColor="@color/color_emergency_red"
            android:textStyle="bold"
            android:paddingStart="10dp"/>

        <TextView
            android:id="@+id/tv_channel_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/color_emergency_red"
            android:paddingEnd="8dp"
            android:visibility="gone"/>

        <!-- × close (collapses banner only) -->
        <TextView
            android:id="@+id/btn_banner_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textSize="20sp"
            android:textColor="@color/color_emergency_red"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ═══ Scrollable content ═══════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Two-column card row ──────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Left: SHOW QR CODE card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/color_surface"
                    android:layout_marginEnd="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SHOW QR CODE"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_text_primary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="12dp"/>

                        <androidx.cardview.widget.CardView
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@color/color_surface">
                            <ImageView
                                android:id="@+id/iv_qr_emergency"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:padding="8dp"
                                android:scaleType="fitCenter"
                                android:contentDescription="QR Code"/>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔒 Doctor Access Only"
                            android:textSize="10sp"
                            android:textColor="@color/color_primary_orange"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Right: CALL RELATIVES card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/color_surface"
                    android:layout_marginStart="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CALL RELATIVES"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_text_primary"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="8dp"/>

                        <!-- Contacts will be added here dynamically -->
                        <LinearLayout
                            android:id="@+id/ll_contacts"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                        <!-- CALL ALL button -->
                        <Button
                            android:id="@+id/btn_call_all"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="CALL ALL →"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:backgroundTint="@color/color_green_call"
                            android:layout_marginTop="10dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── Live Status Feed card ─────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Live Status Feed"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_text_primary"/>

                        <!-- Green pulsing dot -->
                        <View
                            android:id="@+id/v_feed_dot"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@color/color_green_call"/>
                    </LinearLayout>

                    <!-- RecyclerView for status items -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_status_feed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ═══ Bottom Action Bar (fixed) ═══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- CANCEL SOS — dark navy pill -->
        <Button
            android:id="@+id/btn_cancel_sos"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="CANCEL SOS"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:letterSpacing="0.05"
            android:background="@drawable/bg_pill_dark"
            android:layout_marginEnd="8dp"/>

        <!-- 102 POLICE — white outline red pill -->
        <Button
            android:id="@+id/btn_102_police"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="102 POLICE"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_emergency_red"
            android:background="@drawable/bg_pill_outline_red"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</LinearLayout>
