<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ═══ Permissions ═══════════════════════════════════════════════════════ -->

    <!-- Core emergency: SMS fallback and GPS fix -->
    <uses-permission android:name="android.permission.SEND_SMS"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- Battery: keep foreground service alive -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <!-- Android 14+: must explicitly state foreground service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Boot: restart service after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- CALL ALL button in EmergencyActiveActivity -->
    <uses-permission android:name="android.permission.CALL_PHONE"/>

    <!-- Android 13+: Push notification display permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Document picker preview (for images on older Android) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <!-- ═══ Application ════════════════════════════════════════════════════════ -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- ── Activities ──────────────────────────────────────────────────── -->

        <!-- Entry point: decides Onboarding or Main -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Shown once on first install -->
        <activity
            android:name=".activities.OnboardingActivity"
            android:exported="false"/>

        <!-- Medical ID & SOS launcher — appears above keyguard via notification tap -->
        <activity
            android:name=".activities.QuickAccessActivity"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:exported="false"/>

        <!-- Post-SOS active emergency dashboard -->
        <activity
            android:name=".activities.EmergencyActiveActivity"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- AI document upload flow -->
        <activity
            android:name=".activities.DocumentUploadActivity"
            android:exported="false"/>

        <!-- Human validation of AI-extracted data -->
        <activity
            android:name=".activities.ValidationActivity"
            android:exported="false"/>

        <!-- ── Services ────────────────────────────────────────────────────── -->

        <!-- Persistent foreground service — listens for screen-off events -->
        <service
            android:name=".services.EmergencyBackgroundService"
            android:foregroundServiceType="location"
            android:exported="false"/>

        <!-- FCM push notification handler -->
        <service
            android:name=".services.AppFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>
        </service>

        <!-- ── Broadcast Receivers ─────────────────────────────────────────── -->

        <!-- Restarts EmergencyBackgroundService after device reboot -->
        <receiver
            android:name=".services.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>

        <!-- ── Metadata ───────────────────────────────────────────────────── -->

        <!-- Google Maps API Key (set in local.properties as MAPS_API_KEY) -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}"/>

        <!-- Firebase sender ID (configured via google-services.json) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="emergency_extraction_channel"/>

    </application>

</manifest>
