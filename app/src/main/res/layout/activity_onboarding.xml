<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Response"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"
            android:layout_marginTop="32dp"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Let's set up your medical profile"
            android:textSize="15sp"
            android:textColor="@color/color_text_secondary"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"/>

        <!-- Step Indicator -->
        <TextView
            android:id="@+id/tv_step_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 3"
            android:textSize="13sp"
            android:textColor="@color/color_primary_orange"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_gravity="center_horizontal"/>

        <!-- STEP 1: Identity -->
        <LinearLayout
            android:id="@+id/step_one"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personal Information"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/et_full_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Full Name"
                android:inputType="textPersonName"
                android:background="@color/color_surface"
                android:padding="16dp"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_marginBottom="12dp"/>

            <Spinner
                android:id="@+id/spinner_blood_group"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/color_surface"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/et_dob"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Date of Birth (DD/MM/YYYY)"
                android:inputType="date"
                android:background="@color/color_surface"
                android:padding="16dp"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"/>

        </LinearLayout>

        <!-- STEP 2: Emergency Contact -->
        <LinearLayout
            android:id="@+id/step_two"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Contact"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/et_contact_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Contact Name"
                android:inputType="textPersonName"
                android:background="@color/color_surface"
                android:padding="16dp"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/et_contact_phone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Contact Phone Number"
                android:inputType="phone"
                android:background="@color/color_surface"
                android:padding="16dp"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"/>

        </LinearLayout>

        <!-- STEP 3: Conditions -->
        <LinearLayout
            android:id="@+id/step_three"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medical Conditions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select all that apply"
                android:textSize="13sp"
                android:textColor="@color/color_text_secondary"
                android:layout_marginBottom="16dp"/>

            <CheckBox android:id="@+id/cb_diabetes"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Diabetes"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:buttonTint="@color/color_primary_orange"/>

            <CheckBox android:id="@+id/cb_hypertension"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Hypertension"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:buttonTint="@color/color_primary_orange"/>

            <CheckBox android:id="@+id/cb_heart"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Heart Disease"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:buttonTint="@color/color_primary_orange"/>

            <CheckBox android:id="@+id/cb_asthma"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Asthma"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:buttonTint="@color/color_primary_orange"/>

            <CheckBox android:id="@+id/cb_other"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Other"
                android:textSize="15sp"
                android:textColor="@color/color_text_primary"
                android:buttonTint="@color/color_primary_orange"/>

        </LinearLayout>

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:gravity="end">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="120dp"
                android:layout_height="52dp"
                android:text="Back"
                android:visibility="gone"
                android:backgroundTint="@color/color_surface"
                android:textColor="@color/color_text_primary"
                android:layout_marginEnd="12dp"/>

            <Button
                android:id="@+id/btn_next"
                android:layout_width="160dp"
                android:layout_height="52dp"
                android:text="Next"
                android:backgroundTint="@color/color_primary_orange"
                android:textColor="@android:color/white"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
